rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Leads collection
    match /leads/{leadId} {
      allow read, write: if false;
    }
    
    // Lead index collection
    match /lead_index/{indexId} {
      allow read, write: if false;
    }
    
    // Unmatched Calcom events
    match /unmatched_calcom_events/{eventId} {
      allow read, write: if false;
    }
    
    // Chat analytics collections - allow read/write for service account
    match /evaluation_cases_recent/{caseId} {
      allow read, write: if true;
    }
    
    match /evaluation_cases_archive/{caseId} {
      allow read, write: if true;
    }
    
    match /evaluation_rollups/{rollupId} {
      allow read, write: if true;
    }
    
    match /evaluation_rollups_daily/{date} {
      allow read, write: if true;
    }
    
    match /human_reviews/{reviewId} {
      allow read, write: if true;
    }
  }
}